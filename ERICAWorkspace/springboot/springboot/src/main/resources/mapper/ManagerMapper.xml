<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.backpro.main.model.dao.ManagerMapper">

    <resultMap id="BranchRefMap" type="com.backpro.main.model.vo.Branch">
        <id property="branchId" column="branch_id"/>
    </resultMap>

    <resultMap id="ManagerResultMap" type="com.backpro.main.model.vo.Manager">
        <id     property="managerId"   column="manager_id"/>
        <result property="managerName" column="manager_name"/>
        <result property="department"  column="department"/>
        <result property="team"        column="team"/>
        <result property="rankName"    column="rank_name"/>
        <result property="email"       column="email"/>
        <result property="phone"       column="phone"/>
        <result property="workStatus"  column="work_status"/>
        <result property="isCompany"   column="is_company"/>
        <result property="createdAt"   column="created_at"/>
        <result property="deletedAt"   column="deleted_at"/>
        <association property="branch" resultMap="BranchRefMap"/>
    </resultMap>

    <select id="findByBranchIdAndDeletedAtIsNull" resultMap="ManagerResultMap">
        SELECT * FROM manager
        WHERE branch_id = #{branchId}
          AND deleted_at IS NULL
    </select>

    <select id="findById" resultMap="ManagerResultMap">
        SELECT * FROM manager WHERE manager_id = #{managerId} AND deleted_at IS NULL
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="managerId">
        INSERT INTO manager (branch_id, manager_name, department, team, rank_name,
                             email, phone, work_status, is_company, created_at)
        VALUES (#{branch.branchId}, #{managerName}, #{department}, #{team}, #{rankName},
                #{email}, #{phone}, IFNULL(#{workStatus}, '재직'), IFNULL(#{isCompany}, 'Y'), NOW())
    </insert>

    <update id="update">
        UPDATE manager
        <set>
            <if test="managerName != null">manager_name = #{managerName},</if>
            <if test="department  != null">department   = #{department},</if>
            <if test="team        != null">team         = #{team},</if>
            <if test="rankName    != null">rank_name    = #{rankName},</if>
            <if test="email       != null">email        = #{email},</if>
            <if test="phone       != null">phone        = #{phone},</if>
            <if test="workStatus  != null">work_status  = #{workStatus},</if>
            <if test="isCompany   != null">is_company   = #{isCompany},</if>
        </set>
        WHERE manager_id = #{managerId}
    </update>

</mapper>
